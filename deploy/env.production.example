NODE_ENV=production
API_HOST=127.0.0.1
API_PORT=3002

# PostgreSQL on same VPS
DATABASE_URL=postgresql://anilax_app:CHANGE_STRONG_PASSWORD@127.0.0.1:5432/anilax_software

# Your live site URL(s) — comma-separated
CORS_ORIGINS=https://YOUR_DOMAIN.com,https://www.YOUR_DOMAIN.com

# Leave empty when Nginx serves site + /api on same domain (recommended)
# VITE_API_URL=

# Admin: https://YOUR_DOMAIN.com/admin
ADMIN_PASSWORD=use-a-long-random-password-here
