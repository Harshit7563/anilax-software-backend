# Copy to /var/www/anilax-software-backend/.env on VPS
# vps-setup.sh can create this from env.vps on first run

NODE_ENV=production
API_HOST=127.0.0.1
API_PORT=3001

# Supabase or local Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/anilax_software

DOMAIN=anilaxsoftware.com
CORS_ORIGINS=https://anilaxsoftware.com,https://www.anilaxsoftware.com

ADMIN_USERNAME=Bawji
ADMIN_PASSWORD=change-me-strong-password

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
